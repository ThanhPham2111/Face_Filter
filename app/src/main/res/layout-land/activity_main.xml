<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_auth_screen"
    android:orientation="vertical">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messageLists"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="6dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp" />

    <LinearLayout
        android:id="@+id/uploadStatusContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_input_pastel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/uploadStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/uploading_media"
            android:textColor="@color/pastel_text_hint"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/cancelUploadBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_action_icon_button"
            android:contentDescription="@string/cancel_upload"
            android:onClick="handleOnClick"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/pastel_blue_700" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/enterTxt_Cnt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_chat_input_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp">

        <ImageButton
            android:id="@+id/attachImageBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_action_icon_button"
            android:contentDescription="@string/attach_image"
            android:onClick="handleOnClick"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="@color/pastel_blue_700" />

        <EditText
            android:id="@+id/sender1Text"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_pastel"
            android:hint="@string/enter_text"
            android:paddingHorizontal="12dp"
            android:textColor="@color/pastel_text_primary"
            android:textColorHint="@color/pastel_text_hint"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/voiceRecordBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_action_icon_button"
            android:contentDescription="@string/record_voice"
            android:onClick="handleOnClick"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="@color/pastel_blue_700" />

        <ImageButton
            android:id="@+id/sender1TextBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_send_button_pastel"
            android:contentDescription="@string/send_message"
            android:onClick="handleOnClick"
            android:src="@drawable/ic_send_pastel"
            app:tint="@android:color/white" />
    </LinearLayout>

</LinearLayout>
