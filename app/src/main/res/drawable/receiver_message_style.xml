<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <solid android:color="@color/pastel_blue_100" />
        </shape>
    </item>
    <item android:right="2dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:topRightRadius="40dp"
                android:bottomLeftRadius="30dp"
                android:bottomRightRadius="40dp"/>
            <gradient
                android:startColor="@color/white"
                android:endColor="@color/pastel_blue_50"
                android:gradientRadius="@dimen/material_emphasis_medium"
                android:angle="180" />

        </shape>
    </item>
</layer-list>