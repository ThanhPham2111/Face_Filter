<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/pastel_blue_200" />
            <stroke
                android:width="1dp"
                android:color="@color/pastel_blue_500" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/pastel_blue_100" />
            <stroke
                android:width="1dp"
                android:color="@color/pastel_blue_400" />
        </shape>
    </item>
</selector>
