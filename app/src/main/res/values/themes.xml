<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ChatApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/pastel_blue_500</item>
        <item name="colorPrimaryVariant">@color/pastel_blue_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/pastel_blue_200</item>
        <item name="colorSecondaryVariant">@color/pastel_blue_400</item>
        <item name="colorOnSecondary">@color/pastel_text_primary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/pastel_blue_100</item>
        <!-- Customize your theme here. -->
    </style>
</resources>